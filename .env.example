# Copie para .env.local e preencha com os valores do dashboard do Supabase
# (Settings > API). Na Vercel, configure apenas as duas variáveis NEXT_PUBLIC_*.

NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=chave-anon-publica

# Usada SOMENTE pelo seed local (npm run seed). Ignora RLS — nunca exponha
# no navegador nem configure na Vercel.
SUPABASE_SERVICE_ROLE_KEY=chave-service-role
